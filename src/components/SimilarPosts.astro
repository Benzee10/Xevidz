---
import path from "node:path";
import type { CollectionEntry } from "astro:content";
import { getSimilarVideos } from "../utils/similar-posts";
import { getDir } from "@utils/url-utils";

interface Props {
  currentPost: CollectionEntry<"posts">;
}

const { currentPost } = Astro.props;
const similarPosts = currentPost.data.videoUrl ? await getSimilarVideos(currentPost, 4) : [];

function resolveImageUrl(post: CollectionEntry<"posts">, imageUrl: string | undefined): string {
  if (!imageUrl) return '/favicon/favicon-light-192.png';
  if (imageUrl.startsWith("http://") || imageUrl.startsWith("https://")) return imageUrl;
  if (imageUrl.startsWith("/")) return imageUrl;
  const imagePath = path.join("content/posts/", getDir(post.id), imageUrl);
  return new URL(imagePath, Astro.site).toString();
}
---

{similarPosts.length > 0 && (
  <section class="similar-section">
    <div class="similar-header">
      <span class="similar-title">More Videos</span>
    </div>

    <div class="similar-grid">
      {similarPosts.map((post) => (
        <div class="sim-card group">
          <!-- Thumbnail + play button → redirect -->
          <a
            href="https://whatsappad.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="sim-thumb-link"
            aria-label={`Watch ${post.data.title}`}
          >
            <div class="sim-thumb">
              <img
                src={resolveImageUrl(post, post.data.image)}
                alt={post.data.title}
                loading="lazy"
              />
              <div class="sim-play-overlay">
                <div class="sim-play-btn">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              {post.data.duration && (
                <span class="sim-duration">{post.data.duration}</span>
              )}
            </div>
          </a>

          <!-- Info: title → actual post page -->
          <div class="sim-info">
            <a href={`/posts/${post.slug}/`} class="sim-title-link">
              <h3 class="sim-title">{post.data.title}</h3>
            </a>
            <div class="sim-tags">
              {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
                <span class="sim-tag">#{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  /* ===== SECTION ===== */
  .similar-section {
    background: #111111;
    border: 1px solid rgba(201, 168, 76, 0.14);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .similar-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .similar-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C9A84C;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .similar-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(201, 168, 76, 0.35), transparent);
  }

  /* ===== GRID ===== */
  .similar-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }

  @media (min-width: 640px) {
    .similar-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ===== CARD ===== */
  .sim-card {
    background: #141414;
    border: 1px solid rgba(201, 168, 76, 0.10);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sim-card:hover {
    border-color: rgba(201, 168, 76, 0.38);
    box-shadow: 0 6px 24px rgba(0,0,0,0.5), 0 0 14px rgba(201,168,76,0.07);
    transform: translateY(-3px);
    background: #1a1a1a;
  }

  /* ===== THUMBNAIL ===== */
  .sim-thumb-link {
    display: block;
    text-decoration: none;
  }

  .sim-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #0A0A0A;
  }

  .sim-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9) saturate(0.92);
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1), filter 0.3s ease;
  }

  .sim-card:hover .sim-thumb img {
    transform: scale(1.06);
    filter: brightness(1.0) saturate(1.0);
  }

  /* ===== PLAY OVERLAY ===== */
  .sim-play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.26);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .sim-card:hover .sim-play-overlay {
    opacity: 1;
  }

  .sim-play-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #C9A84C, #D4AF37, #B8941F);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 3px rgba(201,168,76,0.25), 0 6px 20px rgba(0,0,0,0.5);
    transform: scale(0.85);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .sim-card:hover .sim-play-btn {
    transform: scale(1.0);
  }

  .sim-play-btn svg {
    width: 18px;
    height: 18px;
    fill: #0A0A0A;
    margin-left: 3px;
  }

  /* ===== DURATION ===== */
  .sim-duration {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.88);
    color: #D4AF37;
    border: 1px solid rgba(201,168,76,0.28);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    backdrop-filter: blur(4px);
  }

  /* ===== INFO ===== */
  .sim-info {
    padding: 0.6rem 0.7rem 0.7rem;
  }

  .sim-title-link {
    display: block;
    text-decoration: none;
    margin-bottom: 0.4rem;
  }

  .sim-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #E0E0E0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s ease;
    margin: 0;
  }

  .sim-card:hover .sim-title {
    color: #FFFFFF;
  }

  /* ===== TAGS ===== */
  .sim-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
  }

  .sim-tag {
    color: #C9A84C;
    border: 1px solid rgba(201, 168, 76, 0.25);
    background: rgba(201, 168, 76, 0.05);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>
