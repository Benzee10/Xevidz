---
import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<div class="footer-gold-line"></div>

<div class="flex flex-col items-center justify-center pb-10 px-6 gap-3">
    <div class="flex items-center gap-2 mb-1">
        <div class="h-px w-12" style="background: linear-gradient(to right, transparent, rgba(201,168,76,0.5))"></div>
        <span class="text-[10px] font-bold tracking-[0.25em] uppercase" style="color: rgba(201,168,76,0.5)">Premium</span>
        <div class="h-px w-12" style="background: linear-gradient(to left, transparent, rgba(201,168,76,0.5))"></div>
    </div>

    <div class="text-[11px] tracking-[0.08em] text-white/30 text-center">
        &copy; <span id="copyright-year">{currentYear}</span>
        <span class="text-[#C9A84C]/60 font-medium">{profileConfig.name}</span>
        &nbsp;&mdash;&nbsp; All Rights Reserved
    </div>

    <div class="flex items-center gap-4 text-[10px] tracking-widest uppercase">
        <a class="transition text-white/25 hover:text-[#C9A84C] duration-200" target="_blank" href={url('rss.xml')}>RSS</a>
        <span class="text-white/10">·</span>
        <a class="transition text-white/25 hover:text-[#C9A84C] duration-200" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a>
    </div>
</div>
